{
  "name": "VectorCompiler",
  "image": "mcr.microsoft.com/devcontainers/rust:1-1-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "1.91.0",
      "profile": "minimal",
      "components": "clippy,rustfmt"
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y jq python3-pip && pip3 install --user check-jsonschema",
  "customizations": {
    "vscode": {
      "extensions": ["rust-lang.rust-analyzer", "tamasfe.even-better-toml"]
    }
  },
  "remoteEnv": {
    "VECTORCOMPILER_ROOT": "${containerWorkspaceFolder}"
  }
}
